# Copy this file to ".env" or ".env.local" (both are gitignored) and fill in
# real values once the Cloudflare Worker in worker/ has been deployed (see
# worker/README.md). Vite only exposes variables prefixed with VITE_ to the
# browser bundle — treat both of these as visible to anyone who views the
# deployed site's JS, not as real secrets.

# The deployed Worker's URL, including the /save-snapshot route, e.g.:
# https://telemedmuk-save-snapshot.<your-subdomain>.workers.dev/save-snapshot
# Printed by `npx wrangler deploy` when run from worker/. If left unset, the
# "save to GitHub" button in the Import Excel tab stays disabled.
VITE_SAVE_WORKER_URL=

# Must exactly match the APP_SHARED_KEY secret set on the Worker via
# `npx wrangler secret put APP_SHARED_KEY` (see worker/README.md). This is a
# basic abuse deterrent only, not a real secret boundary.
VITE_APP_SHARED_KEY=
